.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Downloaded tool binaries (use submodules + setup script instead) ──
# tools_src/ is managed via git submodules and scripts/setup_tools.*
# See tools_src/README.md for download instructions
tools_src/p2rank/p2rank_*/
tools_src/p2rank/*.tar.gz
tools_src/java/*.msi
tools_src/java/*.zip
tools_src/java/jdk-*/
