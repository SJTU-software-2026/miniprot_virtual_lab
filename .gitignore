# ── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ───────────────────────────────────────────
venv/
.venv/
env/
.env

# ── IDE / Editor ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Configuration with real secrets / local paths ──────────────────
